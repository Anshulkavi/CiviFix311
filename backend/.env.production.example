# Django Production Settings
SECRET_KEY=your-secret-key-here-generate-with-django-get-random-secret-key
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_SETTINGS_MODULE=civicfix.settings_prod

# Database Configuration
DB_NAME=civicfix_db
DB_USER=civicfix_user
DB_PASSWORD=strong-database-password-here
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=60

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Email Configuration (Gmail example - use App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=CivicFix 311 <your-email@gmail.com>

# Security Settings
SECURE_SSL_REDIRECT=True
ENABLE_HSTS=False  # Set to True after SSL is confirmed working

# SLA Configuration
SLA_HOURS=24

# Logging
DJANGO_LOG_LEVEL=INFO
