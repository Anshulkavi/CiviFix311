# Render Environment Variables Configuration
# Copy these to Render Dashboard → Service → Environment

# =============================================
# BACKEND SERVICE (civicfix-backend)
# =============================================

# Django Settings (SECRET_KEY and DATABASE_URL are auto-generated by Render)
DEBUG=False
PYTHON_VERSION=3.12.0

# Domain Configuration (REPLACE with your actual Render URLs)
ALLOWED_HOSTS=civicfix-backend.onrender.com
CORS_ALLOWED_ORIGINS=https://civicfix-frontend.onrender.com

# Email Configuration (Optional - for notifications)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# SLA Settings
SLA_HOURS=24

# =============================================
# FRONTEND SERVICE (civicfix-frontend)
# =============================================

# API Configuration (REPLACE with your backend URL)
REACT_APP_API_URL=https://civicfix-backend.onrender.com/api

# =============================================
# NOTES:
# - SECRET_KEY: Auto-generated by Render (no action needed)
# - DATABASE_URL: Auto-linked from database (no action needed)
# - Update ALLOWED_HOSTS and CORS after deployment
# - Email settings are optional for basic functionality
# =============================================
